# gpu-cluster-2:
#   transport: stdio
#   command: npx
#   args: ["-y", "mcp-server-ssh@0.6.0"]
#   env:
#     SSH_HOST: "gpu2.example.com"
#     SSH_USER: "bob"
#     SSH_KEY_PATH: "~/.ssh/id_rsa_gpu2"
#   expose_to: [code-agent]
